# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site URL (for payment callbacks, email links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (https://resend.com) — for transactional email
RESEND_API_KEY=
RESEND_FROM_EMAIL=NASIJ <noreply@yourdomain.com>

# Paymob (https://paymob.com) — Egyptian payment gateway
# Get these from your Paymob dashboard once your merchant account is approved
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=
